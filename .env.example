# База, которую создаёт official postgres image при первом старте.
POSTGRES_DB=orders_db
POSTGRES_USER=orders_user
POSTGRES_PASSWORD=change-me

# Read-only monitoring role для postgres-exporter.
POSTGRES_EXPORTER_USER=postgres_exporter
POSTGRES_EXPORTER_PASSWORD=change-me

# Owner запускает Flyway и владеет объектами schema order_service.
# App user используется order-service в runtime.
ORDER_SERVICE_DB_OWNER_USER=order_service_owner
ORDER_SERVICE_DB_OWNER_PASSWORD=change-me
ORDER_SERVICE_DB_USER=order_service_app
ORDER_SERVICE_DB_PASSWORD=change-me

# Owner запускает Flyway и владеет объектами schema notification_service.
# App user используется notification-service в runtime.
NOTIFICATION_SERVICE_DB_OWNER_USER=notification_service_owner
NOTIFICATION_SERVICE_DB_OWNER_PASSWORD=change-me
NOTIFICATION_SERVICE_DB_USER=notification_service_app
NOTIFICATION_SERVICE_DB_PASSWORD=change-me
