<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Подключаем стандартные Spring Boot logback defaults:
         цвета, формат консоли, переменные CONSOLE_LOG_PATTERN и т.д. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- GELF appender отправляет логи в Graylog input на UDP 12201 -->
    <appender name="GELF" class="de.siegmar.logbackgelf.GelfUdpAppender">
        <graylogHost>localhost</graylogHost>
        <graylogPort>12201</graylogPort>

        <encoder class="de.siegmar.logbackgelf.GelfEncoder">
            <!-- MDC содержит traceId/spanId, их надо отправлять как отдельные поля -->
            <includeMdcData>true</includeMdcData>

            <!-- Добавляем имя сервиса как отдельное поле. -->
            <staticFields>service_name:notification-service</staticFields>

            <!-- Чтобы в Graylog было поле level_name=INFO/WARN/ERROR -->
            <includeLevelName>true</includeLevelName>
        </encoder>
    </appender>

    <!-- AsyncAppender нужен, чтобы приложение не тормозило,
         если Graylog временно медленный или недоступен. -->
    <appender name="ASYNC_GELF" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="GELF"/>
        <neverBlock>true</neverBlock>
    </appender>

    <!-- root logger пишет и в консоль, и в Graylog -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_GELF"/>
    </root>

</configuration>