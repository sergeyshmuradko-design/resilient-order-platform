# -----------------------------------------------------------------------------
# Base image.
# Используем только JRE, так как приложение уже собрано Gradle.
# Это уменьшает размер образа по сравнению с JDK.
# -----------------------------------------------------------------------------
FROM eclipse-temurin:21-jre

# Рабочая директория внутри контейнера.
# Все последующие команды выполняются относительно неё.
WORKDIR /app

# Копируем готовый Spring Boot executable JAR.
# Сборка происходит снаружи (Gradle), контейнер только запускает приложение.
COPY build/libs/*.jar app.jar

# Документируем, что приложение слушает порт 8081.
# EXPOSE не публикует порт автоматически.
EXPOSE 8081

# Запускаем Spring Boot приложение.
ENTRYPOINT ["java", "-jar", "app.jar"]