  "panels": [
    {
      "id": 1,
      "title": "Service Availability / Доступность сервисов",
      "description": "RU: Показывает, доступен ли Prometheus endpoint каждого выбранного экземпляра: 1 — доступен, 0 — недоступен. Смотрите на переходы к 0 и пропуски данных.\n\nEN: Shows whether each selected instance is reachable by Prometheus: 1 means up, 0 means down. Watch for transitions to 0 and missing data.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "annotations": {
          "clustering": -1,
          "multiLane": false
        },
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "enableFacetedFilter": false,
          "overflow": "ellipsis",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "min by (job, instance) (up{job=~\"$service\",instance=~\"$instance\"})",
          "legendFormat": "{{job}} {{instance}}",
          "range": true,
          "refId": "A",
          "hide": false,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "transformations": [],
      "links": []
    },
    {
      "id": 2,
      "title": "HTTP Request Rate / Частота HTTP-запросов",
      "description": "RU: Количество запросов в секунду по сервисам и URI. Сопоставляйте рост нагрузки с latency, ошибками, потоками Tomcat и пулом соединений.\n\nEN: Requests per second by service and URI. Correlate traffic growth with latency, errors, Tomcat threads, and the connection pool.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "thresholds": {
